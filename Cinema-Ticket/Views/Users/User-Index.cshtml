@model IEnumerable<CinemaTicket.Models.Entities.User>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3>👥 User Management</h3>
                    @if (Context.Session.GetString("Username") != null)
                    {
                        <small>Logged in as: <strong>@Context.Session.GetString("Username")</strong></small>
                    }
                </div>
                <div class="card-body">
                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-info">
                            <strong>ℹ️ No users found.</strong>
                            <p class="mb-0">The database has no users yet. Please run database initialization.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ID</th>
                                        <th>Username</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Phone</th>
                                        <th>Role</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model)
                                    {
                                        <tr>
                                            <td>@user.Id</td>
                                            <td>
                                                <strong>@user.Username</strong>
                                            </td>
                                            <td>@user.FirstName @user.LastName</td>
                                            <td>@user.Email</td>
                                            <td>@user.PhoneNumber</td>
                                            <td>
                                                @if (user.IsAdmin)
                                                {
                                                    <span class="badge bg-danger">ADMIN</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">USER</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" asp-route-id="@user.Id" 
                                                       class="btn btn-sm btn-info" title="View Details">
                                                        👁️ Details
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@user.Id" 
                                                       class="btn btn-sm btn-warning" title="Edit User">
                                                        ✏️ Edit
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@user.Id" 
                                                       class="btn btn-sm btn-danger" title="Delete User">
                                                        🗑️ Delete
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="alert alert-info mt-3">
                            <strong>📊 Summary:</strong> Total users: <strong>@Model.Count()</strong> 
                            (@Model.Count(u => u.IsAdmin) admins, @Model.Count(u => !u.IsAdmin) regular users)
                        </div>
                    }
                </div>
            </div>

            <div class="card mt-3 border-warning">
                <div class="card-header bg-warning">
                    <h5>🔒 Concurrency Protection Active</h5>
                </div>
                <div class="card-body">
                    <p><strong>How to test concurrency protection:</strong></p>
                    <ol>
                        <li>Open two browser windows (one normal, one incognito)</li>
                        <li>Login as admin in both windows</li>
                        <li>Click "Edit" on the same user (e.g., jane) in both windows</li>
                        <li>Window 1: Change email to <code>test1@example.com</code> (DON'T SAVE YET)</li>
                        <li>Window 2: Change email to <code>test2@example.com</code> and <strong>SAVE</strong> ✅</li>
                        <li>Window 1: Now click <strong>SAVE</strong> → ❌ <strong>Conflict detected!</strong></li>
                    </ol>
                    <p class="mb-0">
                        <a asp-controller="Test" asp-action="AdminConcurrencyTest" class="btn btn-info">
                            📋 View Detailed Test Instructions
                        </a>
                        <a asp-controller="Test" asp-action="ConcurrencyDemo" class="btn btn-success">
                            🧪 Run Automated Demo
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
