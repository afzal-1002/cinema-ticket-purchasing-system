@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">🔐 Login</h3>
                </div>
                <div class="card-body">
                    @* ✅ UPDATED: Changed asp-controller to "Account" instead of "Users" *@
                    <form method="post" asp-action="Login" asp-controller="Account">
                        @Html.AntiForgeryToken()

                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <div class="form-group mb-3">
                            <label for="username" class="form-label">Username</label>
                            <input type="text" class="form-control" id="username" name="username" required autofocus />
                        </div>

                        <div class="form-group mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" name="password" required />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                🚪 Login
                            </button>
                        </div>
                    </form>

                    <hr class="my-3" />

                    <div class="text-center">
                        <p class="mb-0">Don't have an account?</p>
                        @* ✅ UPDATED: Point to Account controller *@
                        <a asp-action="Register" asp-controller="Account" class="btn btn-outline-secondary mt-2">
                            📝 Register Here
                        </a>
                    </div>

                    <div class="alert alert-info mt-3" role="alert">
                        <strong>Test Credentials:</strong><br/>
                        <small>
                            <strong>Admin:</strong> admin / admin<br/>
                            <strong>Admin 2:</strong> admin2 / admin123<br/>
                            <strong>User:</strong> jane / 123
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
