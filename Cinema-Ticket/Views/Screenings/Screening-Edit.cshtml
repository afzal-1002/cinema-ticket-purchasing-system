@model CinemaTicket.Models.Entities.Screening

@{
    ViewData["Title"] = "Edit Screening";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil"></i> Edit Screening
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        
                        @* ✅ CRITICAL: HIDDEN FIELDS *@
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" name="originalRowVersionBase64" value="@ViewBag.OriginalRowVersion" />

                        <div class="mb-3">
                            <label for="cinemaId" class="form-label">Cinema Hall</label>
                            <select name="cinemaId" class="form-select" required>
                                <option value="">-- Select Cinema --</option>
                                @if (ViewBag.Cinemas != null)
                                {
                                    @foreach (var cinema in ViewBag.Cinemas)
                                    {
                                        <option value="@cinema.Id" selected="@(cinema.Id == Model.CinemaId)">
                                            @cinema.Name (@cinema.RoomNumber) - @(cinema.TotalRows * cinema.SeatsPerRow) seats
                                        </option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="movieTitle" class="form-label">Movie Title</label>
                            <input name="movieTitle" value="@Model.MovieTitle" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label for="startTime" class="form-label">Start Time</label>
                            <input name="startTime" type="datetime-local" 
                                   value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" 
                                   class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label for="endTime" class="form-label">End Time</label>
                            <input name="endTime" type="datetime-local" 
                                   value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" 
                                   class="form-control" required />
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-circle"></i> Update Screening
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>

                        <div class="mt-4">
                            <a asp-action="Index" class="btn btn-secondary">Back to List</a>  <!-- ✅ FIXED -->
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}