@model IEnumerable<CinemaTicket.Models.Entities.Screening>

@{
    ViewData["Title"] = "Screenings";
    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
    var availableSeatsDict = ViewBag.AvailableSeats as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">Movie Screenings</h2>
            <p class="text-muted">Browse and book your cinema tickets</p>
        </div>
        <div class="col-md-4 text-end">
            @if (isAdmin)
            {
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Add Screening
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <h5><i class="bi bi-info-circle"></i> No Screenings Available</h5>
            <p class="mb-0">No movie screenings have been scheduled yet.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var screening in Model)
            {
                int availableSeats = availableSeatsDict.ContainsKey(screening.Id) ? availableSeatsDict[screening.Id] : 0;
                
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@screening.MovieTitle</h5>
                            <h6 class="card-subtitle mb-3 text-muted">
                                @screening.Cinema?.Name (@screening.Cinema?.RoomNumber)
                            </h6>
                            
                            <div class="mb-2">
                                <i class="bi bi-calendar-event text-primary"></i>
                                <strong>@screening.StartTime.ToString("MMM dd, yyyy")</strong>
                            </div>
                            
                            <div class="mb-2">
                                <i class="bi bi-clock text-primary"></i>
                                @screening.StartTime.ToString("h:mm tt") - @screening.EndTime.ToString("h:mm tt")
                            </div>
                            
                            <div class="mb-3">
                                @if (availableSeats > 0)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle"></i> @availableSeats seats available
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-x-circle"></i> Sold Out
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="card-footer bg-transparent">
                            @if (isAdmin)
                            {
                                <!-- Admin Actions -->
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@screening.Id" 
                                       class="btn btn-sm btn-info text-white flex-fill" 
                                       title="View Details">
                                        <i class="bi bi-info-circle"></i> Details
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@screening.Id" 
                                       class="btn btn-sm btn-warning flex-fill" 
                                       title="Edit Screening">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@screening.Id" 
                                       class="btn btn-sm btn-danger flex-fill" 
                                       title="Delete Screening">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            }
                            else
                            {
                                <!-- User Actions -->
                                <div class="d-flex gap-2 flex-wrap">
                                    @if (availableSeats > 0 && screening.StartTime > DateTime.Now)
                                    {
                                        <a asp-controller="Reservations" asp-action="SeatMap" asp-route-id="@screening.Id" 
                                           class="btn btn-primary flex-fill">
                                            <i class="bi bi-ticket-perforated"></i> Book Tickets
                                        </a>
                                    }
                                    else if (screening.StartTime <= DateTime.Now)
                                    {
                                        <button class="btn btn-secondary flex-fill" disabled>
                                            <i class="bi bi-clock-history"></i> Screening Ended
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary flex-fill" disabled>
                                            <i class="bi bi-x-circle"></i> Sold Out
                                        </button>
                                    }
                                    <a asp-action="Details" asp-route-id="@screening.Id" 
                                       class="btn btn-outline-info flex-fill">
                                        <i class="bi bi-info-circle"></i> Details
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert-success');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}