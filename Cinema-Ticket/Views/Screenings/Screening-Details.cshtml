@model CinemaTicket.Models.Entities.Screening

@{
    ViewData["Title"] = "Screening Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h2>@Model.MovieTitle</h2>
            <hr />
            
            <dl class="row">
                <dt class="col-sm-3">Cinema</dt>
                <dd class="col-sm-9">@Model.Cinema?.Name (@Model.Cinema?.RoomNumber)</dd>

                <dt class="col-sm-3">Start Time</dt>
                <dd class="col-sm-9">@Model.StartTime.ToString("dddd, MMMM dd, yyyy - h:mm tt")</dd>

                <dt class="col-sm-3">End Time</dt>
                <dd class="col-sm-9">@Model.EndTime.ToString("dddd, MMMM dd, yyyy - h:mm tt")</dd>

                <dt class="col-sm-3">Capacity</dt>
                <dd class="col-sm-9">@(Model.Cinema?.TotalRows * Model.Cinema?.SeatsPerRow) seats</dd>

                <dt class="col-sm-3">Available Seats</dt>
                <dd class="col-sm-9">
                    @{
                        var totalSeats = (Model.Cinema?.TotalRows ?? 0) * (Model.Cinema?.SeatsPerRow ?? 0);
                        var reservedSeats = Model.Reservations?.Count ?? 0;
                        var availableSeats = totalSeats - reservedSeats;
                    }
                    @availableSeats / @totalSeats
                </dd>
            </dl>

            <div class="mt-4">
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                
                @* ✅ FIXED: Correct link to seat map *@
                <a asp-controller="Reservations" asp-action="SeatMap" asp-route-id="@Model.Id" class="btn btn-primary btn-lg">
                    <i class="bi bi-ticket-perforated"></i> Book Seats
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>Seat Map</h5>
                </div>
                <div class="card-body">
                    @if (Model.Reservations != null && Model.Reservations.Any())
                    {
                        <p class="text-muted">Reserved Seats:</p>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var reservation in Model.Reservations.OrderBy(r => r.SeatNumber))
                            {
                                <span class="badge bg-danger">Seat @reservation.SeatNumber</span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-success">All seats available!</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
