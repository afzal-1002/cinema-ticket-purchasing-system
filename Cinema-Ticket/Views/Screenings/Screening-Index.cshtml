@model IEnumerable<CinemaTicket.Models.Entities.Screening>

@{
    ViewData["Title"] = "Movie Screenings";
    var userId = Context.Session.GetInt32("UserId");
    var isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Movie Screenings</h2>
        <div class="d-flex gap-2 align-items-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-house-door"></i> Home
            </a>
            @if (isAdmin)
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Create new screening
                </a>
            }
        </div>
    </div>

    <div class="row">
        @foreach (var screening in Model.GroupBy(s => s.MovieTitle))
        {
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@screening.Key</h5>
                        <div class="list-group mt-3">
                            @{
                                var bookedDict = ViewBag.BookedCounts as IDictionary<int, int> ?? new Dictionary<int, int>();
                            }

                            @foreach (var show in screening.OrderBy(s => s.StartTime))
                            {
                                <div class="list-group-item list-group-item-action">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <small class="text-muted">@show.StartTime.ToString("MMM dd, HH:mm")</small>
                                            <div>@(show.Cinema?.Name ?? $"Cinema {show.CinemaId}")</div>
                                            @* seat counts: total, booked, free *@
                                            @{ 
                                                var totalSeats = 0;
                                                if (show.Cinema != null)
                                                {
                                                    totalSeats = show.Cinema.TotalRows * show.Cinema.SeatsPerRow;
                                                }
                                                var booked = bookedDict.ContainsKey(show.Id) ? bookedDict[show.Id] : 0;
                                                var free = Math.Max(0, totalSeats - booked);
                                            }
                                            <small class="text-muted">Total seats: @totalSeats — Booked: @booked — Free: @free</small>
                                        <!-- Delete Confirmation Modal -->
                                        <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content">
                                                    <div class="modal-body text-center py-4">
                                                        <p class="mb-0">Are you sure you want to delete this Screening?</p>
                                                    </div>
                                                    <div class="modal-footer justify-content-center">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="button" class="btn btn-danger" id="confirmDeleteBtn">OK</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <script>
                                            // Delete screening modal handling
                                            (function() {
                                                let formToSubmit = null;
                                                document.querySelectorAll('.delete-screening-btn').forEach(btn => {
                                                    btn.addEventListener('click', function(e) {
                                                        e.preventDefault();
                                                        formToSubmit = this.closest('.delete-form');
                                                        const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
                                                        modal.show();
                                                    });
                                                });

                                                document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
                                                    if (formToSubmit) {
                                                        formToSubmit.submit();
                                                    }
                                                });
                                            })();
                                        </script>
                                        </div>
                                        <div class="d-flex">
                                            @{ var isSoldOut = free == 0; }
                                            @if (isSoldOut)
                                            {
                                                <span class="btn btn-secondary btn-sm me-2 disabled">Sold out</span>
                                            }
                                            else
                                            {
                                                if (userId.HasValue)
                                                {
                                                    <a asp-action="Details" asp-route-id="@show.Id" 
                                                       class="btn btn-primary btn-sm me-2">
                                                        Book Seats
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a asp-controller="Users" asp-action="Login" class="btn btn-outline-primary btn-sm me-2">Login to book</a>
                                                }
                                            }
                                            @if (isAdmin)
                                            {
                                                <form asp-action="Delete" method="post" class="d-inline delete-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@show.Id" />
                                                    <button type="button" class="btn btn-danger btn-sm delete-screening-btn">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No screenings available at the moment.
        </div>
    }
</div>
