@model IEnumerable<CinemaTicket.Models.Entities.Screening>
@{
    ViewData["Title"] = ViewBag.MovieTitle ?? "Movie Details";
    var movieTitle = ViewBag.MovieTitle as string;
}

<div class="container mt-4">
    <h1>@movieTitle</h1>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> No upcoming screenings available for this movie.
        </div>
    }
    else
    {
        <h4>Upcoming Screenings</h4>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Cinema</th>
                        <th>Room</th>
                        <th>Start Time</th>
                        <th>End Time</th>
                        <th>Duration</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var screening in Model)
                    {
                        var duration = (screening.EndTime - screening.StartTime).TotalMinutes;
                        <tr>
                            <td>@screening.Cinema?.Name</td>
                            <td>Room @screening.Cinema?.RoomNumber</td>
                            <td>@screening.StartTime.ToString("MMM dd, yyyy h:mm tt")</td>
                            <td>@screening.EndTime.ToString("h:mm tt")</td>
                            <td>@((int)duration) min</td>
                            <td>
                                <a asp-controller="Screenings" asp-action="Details" asp-route-id="@screening.Id" class="btn btn-sm btn-success">
                                    <i class="bi bi-grid-3x3"></i> Select Seats
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-controller="Movie" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Movies
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-house-door"></i> Home
        </a>
    </div>
</div>
