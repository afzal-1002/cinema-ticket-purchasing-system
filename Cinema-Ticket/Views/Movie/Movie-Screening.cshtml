@model CinemaTicket.Models.Entities.Screening
@{
    ViewData["Title"] = "Screening Details";
}

<div class="container mt-4">
    <h1>@Model.MovieTitle</h1>
    <hr />

    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Screening Information</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Cinema:</strong> @Model.Cinema?.Name</p>
                    <p><strong>Room:</strong> @Model.Cinema?.RoomNumber</p>
                    <p><strong>Start Time:</strong> @Model.StartTime.ToString("MMMM dd, yyyy h:mm tt")</p>
                    <p><strong>End Time:</strong> @Model.EndTime.ToString("h:mm tt")</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Duration:</strong> @((int)(Model.EndTime - Model.StartTime).TotalMinutes) minutes</p>
                    <p><strong>Auditorium Size:</strong> @Model.Cinema?.TotalRows rows × @Model.Cinema?.SeatsPerRow seats</p>
                    <p><strong>Total Seats:</strong> @((Model.Cinema?.TotalRows ?? 0) * (Model.Cinema?.SeatsPerRow ?? 0))</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Screenings" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary btn-lg">
            <i class="bi bi-grid-3x3"></i> View Seat Map & Book Tickets
        </a>
    </div>

    <div class="mt-3">
        <a asp-controller="Movie" asp-action="Details" asp-route-title="@Model.MovieTitle" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Screenings
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-house-door"></i> Home
        </a>
    </div>
</div>
