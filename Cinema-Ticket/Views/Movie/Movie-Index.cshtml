@model IEnumerable<string>
@{
    ViewData["Title"] = "Movies";
}

<div class="container mt-4">
    <h1>Available Movies</h1>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">No movies available at the moment.</div>
    }
    else
    {
        <div class="row">
            @foreach (var movieTitle in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">
                                <i class="bi bi-film"></i> @movieTitle
                            </h5>
                            <div class="mt-auto">
                                <a asp-controller="Movie" asp-action="Details" asp-route-title="@movieTitle" class="btn btn-primary w-100">
                                    <i class="bi bi-calendar-event"></i> View Screenings
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-house-door"></i> Back to Home
        </a>
    </div>
</div>
