@{
    ViewData["Title"] = "Admin Concurrency Test Instructions";
}

<div class="container mt-5">
    <h1>🧪 Admin Concurrency Test - Step by Step</h1>

    <div class="alert alert-info">
        <strong>Objective:</strong> Demonstrate that two admins cannot overwrite each other's changes when editing the same user simultaneously.
    </div>

    <div class="card mt-4">
        <div class="card-header bg-primary text-white">
            <h4>📋 Test Steps</h4>
        </div>
        <div class="card-body">
            <h5>Setup (Use Two Browser Windows/Tabs):</h5>
            <ol>
                <li>
                    <strong>Browser 1:</strong> Login as admin
                    <ul>
                        <li>Go to: <a href="/Users/Login" target="_blank">/Users/Login</a></li>
                        <li>Username: <code>admin</code></li>
                        <li>Password: <code>admin</code></li>
                    </ul>
                </li>
                <li>
                    <strong>Browser 2 (Incognito/Private Window):</strong> Login as admin again
                    <ul>
                        <li>Go to: <a href="/Users/Login" target="_blank">/Users/Login</a></li>
                        <li>Username: <code>admin</code></li>
                        <li>Password: <code>admin</code></li>
                    </ul>
                </li>
            </ol>

            <hr/>

            <h5>Test Concurrency Conflict:</h5>
            <ol start="3">
                <li>
                    <strong>Browser 1:</strong> Go to <a href="/Users/Index" target="_blank">/Users/Index</a>
                    <ul>
                        <li>Click <strong>"Edit"</strong> on user <code>jane</code></li>
                        <li>Change Email to: <code>admin1@example.com</code></li>
                        <li><strong>DO NOT SAVE YET!</strong></li>
                    </ul>
                </li>
                <li>
                    <strong>Browser 2:</strong> Go to <a href="/Users/Index" target="_blank">/Users/Index</a>
                    <ul>
                        <li>Click <strong>"Edit"</strong> on the same user <code>jane</code></li>
                        <li>Change Email to: <code>admin2@example.com</code></li>
                        <li>Change Phone to: <code>9999999999</code></li>
                        <li><strong>Click "Save Changes"</strong> ✅ (This will succeed)</li>
                    </ul>
                </li>
                <li>
                    <strong>Browser 1:</strong> Now click <strong>"Save Changes"</strong>
                    <ul>
                        <li>❌ <strong>CONFLICT DETECTED!</strong></li>
                        <li>You'll see a red alert showing:</li>
                        <ul>
                            <li>Current database values (saved by Browser 2/Admin2)</li>
                            <li>Your attempted changes (not saved)</li>
                            <li>Message: "This user record was modified by another administrator"</li>
                        </ul>
                    </ul>
                </li>
            </ol>

            <hr/>

            <h5>Expected Result:</h5>
            <div class="alert alert-success">
                <strong>✅ Concurrency Protection Working!</strong>
                <ul class="mb-0">
                    <li>Browser 2's changes are saved to database</li>
                    <li>Browser 1's changes are <strong>rejected</strong></li>
                    <li>Browser 1 admin sees detailed conflict message</li>
                    <li>Browser 1 admin must refresh to see latest data before editing again</li>
                    <li><strong>No data is overwritten!</strong></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="card mt-4 border-warning">
        <div class="card-header bg-warning">
            <h5>⚠️ What Prevents the Conflict?</h5>
        </div>
        <div class="card-body">
            <p><strong>The <code>[Timestamp]</code> attribute on <code>User.RowVersion</code>:</strong></p>
            <pre class="bg-light p-3"><code>// Models/Entities/User.cs
[Timestamp]
public byte[] RowVersion { get; set; } = Array.Empty&lt;byte&gt;();</code></pre>

            <p class="mt-3"><strong>How it works:</strong></p>
            <ol>
                <li>When Browser 1 loads the edit page → captures RowVersion = <code>ABC123</code></li>
                <li>When Browser 2 loads the edit page → captures same RowVersion = <code>ABC123</code></li>
                <li>Browser 2 saves → Database updates RowVersion to <code>XYZ789</code></li>
                <li>Browser 1 tries to save with old RowVersion <code>ABC123</code></li>
                <li>Database sees mismatch → throws <code>DbUpdateConcurrencyException</code></li>
                <li>Controller catches exception → shows conflict details to Browser 1 admin</li>
            </ol>
        </div>
    </div>

    <div class="text-center mt-4">
        <a href="/Users/Login" class="btn btn-primary btn-lg">🔐 Start Test - Login as Admin</a>
        <a href="/Test/ConcurrencyDemo" class="btn btn-info">📊 View Automated Demo</a>
    </div>
</div>