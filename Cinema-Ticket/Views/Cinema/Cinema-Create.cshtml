@model CinemaTicket.Models.Entities.Cinema

@{
    ViewData["Title"] = "Create Cinema";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Add New Cinema</h4>
                </div>
                <div class="card-body">
                    @if (!ViewContext.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <ul class="mb-0">
                                @foreach (var modelError in ViewContext.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@modelError.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    }

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RoomNumber" class="form-label"></label>
                            <input asp-for="RoomNumber" class="form-control" />
                            <span asp-validation-for="RoomNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TotalRows" class="form-label"></label>
                            <input asp-for="TotalRows" class="form-control" type="number" />
                            <span asp-validation-for="TotalRows" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SeatsPerRow" class="form-label"></label>
                            <input asp-for="SeatsPerRow" class="form-control" type="number" />
                            <span asp-validation-for="SeatsPerRow" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <input type="submit" value="Create Cinema" class="btn btn-primary" />
                            <a asp-action="Index" asp-controller="Cinema" class="btn btn-secondary">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
