@model IEnumerable<CinemaTicket.Models.Entities.Cinema>
@{
    ViewData["Title"] = "Cinemas";
    var isAdmin = Context.Session.GetString("IsAdmin") == "True";
}

<style>
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
    }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-building"></i> @(isAdmin ? "Manage Cinemas" : "View Cinemas")
        </h2>
        
        @* ✅ Only show Add New Cinema button for admins *@
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Cinema
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No cinema halls available.
            @if (isAdmin)
            {
                <a asp-action="Create" class="alert-link">Create your first cinema!</a>
            }
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var cinema in Model)
            {
                var totalSeats = cinema.TotalRows * cinema.SeatsPerRow;
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-header bg-dark text-white">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-building"></i> @cinema.Name
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <p class="mb-2">
                                    <i class="bi bi-door-open text-primary"></i> 
                                    <strong>Room:</strong> @cinema.RoomNumber
                                </p>
                                <p class="mb-2">
                                    <i class="bi bi-layout-three-columns text-success"></i> 
                                    <strong>Rows:</strong> @cinema.TotalRows
                                </p>
                                <p class="mb-2">
                                    <i class="bi bi-grid-3x3-gap text-warning"></i> 
                                    <strong>Seats Per Row:</strong> @cinema.SeatsPerRow
                                </p>
                                <p class="mb-0">
                                    <i class="bi bi-people-fill text-info"></i> 
                                    <strong>Total Capacity:</strong> 
                                    <span class="badge bg-primary">@totalSeats seats</span>
                                </p>
                            </div>
                            
                            <div class="mb-2">
                                <small class="text-muted">
                                    <i class="bi bi-hash"></i> ID: @cinema.Id
                                </small>
                            </div>
                        </div>
                        
                        @* ✅ Only show action buttons for admins *@
                        @if (isAdmin)
                        {
                            <div class="card-footer bg-light">
                                <div class="d-grid gap-2">
                                    <a asp-action="Details" asp-route-id="@cinema.Id" 
                                       class="btn btn-info">
                                        <i class="bi bi-info-circle"></i> View Details
                                    </a>
                                    
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@cinema.Id" 
                                           class="btn btn-warning">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        
                                        <a asp-action="Delete" asp-route-id="@cinema.Id" 
                                           class="btn btn-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
