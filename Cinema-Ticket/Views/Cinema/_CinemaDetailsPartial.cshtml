@model CinemaTicket.Models.Entities.Cinema

<div>
    <h5>@Model.Name</h5>
    <p><strong>Room:</strong> @Model.RoomNumber</p>
    <p><strong>Capacity:</strong> @Model.TotalRows rows × @Model.SeatsPerRow seats per row (@(Model.TotalRows * Model.SeatsPerRow) total)</p>
    <div class="mt-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">Open Details</a>
        @if (Context.Session.GetString("IsAdmin") == "true")
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-secondary ms-2">Edit</a>
            <form asp-action="Delete" method="post" class="d-inline ms-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="button" class="btn btn-sm btn-danger" data-confirm="Are you sure you want to delete this cinema and all related bookings?">Delete</button>
            </form>
        }
    </div>
</div>
